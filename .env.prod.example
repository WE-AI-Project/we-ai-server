# Production app runtime
APP_PROFILE=prod
APP_CONTAINER_NAME=we-ai-app
BACKEND_UPSTREAM=app:8080
NGINX_SERVER_NAME=your-backend.up.railway.app
APP_BASE_URL=https://your-backend.up.railway.app
APP_FRONTEND_BASE_URL=https://we-ai-client.vercel.app
APP_API_DOMAIN=your-backend.up.railway.app
APP_FRONTEND_DOMAIN=we-ai-client.vercel.app
APP_STORAGE_CONSOLE_DOMAIN=minio.example.com

# Database
DB_PORT=3306
DB_NAME=we_ai
DB_USERNAME=weai
DB_PASSWORD=change-this-production-db-password
DB_ROOT_PASSWORD=change-this-production-root-password

# Docker Compose images
MYSQL_IMAGE_TAG=8.4
MYSQL_CONTAINER_NAME=we-ai-mysql
NGINX_IMAGE_TAG=stable-alpine
NGINX_CONTAINER_NAME=we-ai-nginx
NGINX_PORT=80
MINIO_IMAGE_TAG=latest
MINIO_MC_IMAGE_TAG=latest
MINIO_CONTAINER_NAME=we-ai-minio
MINIO_INIT_CONTAINER_NAME=we-ai-minio-init
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-production-minio-password
MINIO_PUBLIC_BUCKET=we-ai-public
MINIO_PRIVATE_BUCKET=we-ai-private

# JWT
JWT_SECRET=change-this-production-secret-key-at-least-32-bytes
JWT_ISSUER=we-ai-production
JWT_ACCESS_TOKEN_EXPIRATION=PT30M
JWT_REFRESH_TOKEN_EXPIRATION=P7D
SWAGGER_ENABLED=false

# Social login
KAKAO_CLIENT_ID=your-production-kakao-client-id
KAKAO_REDIRECT_URI=https://your-backend.up.railway.app/api/v1/auth/kakao/callback
NAVER_CLIENT_ID=your-production-naver-client-id
NAVER_CLIENT_SECRET=your-production-naver-client-secret
NAVER_REDIRECT_URI=https://your-backend.up.railway.app/api/v1/auth/naver/callback
GOOGLE_CLIENT_ID=your-production-google-client-id
GOOGLE_CLIENT_SECRET=your-production-google-client-secret
GOOGLE_REDIRECT_URI=https://your-backend.up.railway.app/api/v1/auth/google/callback

# Verification code delivery
AUTH_VERIFICATION_MOCK_ENABLED=false
AUTH_VERIFICATION_EXPOSE_CODE_IN_RESPONSE=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-sender@example.com
MAIL_PASSWORD=your-app-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
AUTH_VERIFICATION_EMAIL_FROM=your-sender@example.com
