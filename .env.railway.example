# Railway backend service variables
# Replace the MySQL service name in the reference variables below if your Railway DB service
# is not literally named "MySQL".

SPRING_PROFILES_ACTIVE=prod
PORT=8080

# Railway MySQL reference variables
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_NAME=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# Public URLs
APP_BASE_URL=https://your-backend.up.railway.app
APP_LOCAL_BASE_URL=https://your-backend.up.railway.app
APP_FRONTEND_BASE_URL=https://we-ai-client.vercel.app
APP_API_DOMAIN=your-backend.up.railway.app
APP_FRONTEND_DOMAIN=we-ai-client.vercel.app
APP_STORAGE_CONSOLE_DOMAIN=minio.example.com

# JWT
JWT_SECRET=change-this-production-secret-key-at-least-32-bytes
JWT_ISSUER=we-ai-production
JWT_ACCESS_TOKEN_EXPIRATION=PT30M
JWT_REFRESH_TOKEN_EXPIRATION=P7D
SWAGGER_ENABLED=false

# Social login
KAKAO_CLIENT_ID=your-production-kakao-client-id
KAKAO_REDIRECT_URI=https://your-backend.up.railway.app/api/v1/auth/kakao/callback
NAVER_CLIENT_ID=your-production-naver-client-id
NAVER_CLIENT_SECRET=your-production-naver-client-secret
NAVER_REDIRECT_URI=https://your-backend.up.railway.app/api/v1/auth/naver/callback
GOOGLE_CLIENT_ID=your-production-google-client-id
GOOGLE_CLIENT_SECRET=your-production-google-client-secret
GOOGLE_REDIRECT_URI=https://your-backend.up.railway.app/api/v1/auth/google/callback
