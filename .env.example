# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=we_ai
DB_USERNAME=weai
DB_PASSWORD=change-me-db-password
DB_ROOT_PASSWORD=change-me-root-password

# Local development
APP_PROFILE=dev
APP_CONTAINER_NAME=we-ai-app
BACKEND_UPSTREAM=host.docker.internal:8080
NGINX_SERVER_NAME=localhost
APP_BASE_URL=http://localhost:8080
APP_FRONTEND_BASE_URL=http://localhost:3000
APP_API_DOMAIN=localhost
APP_FRONTEND_DOMAIN=localhost
APP_STORAGE_CONSOLE_DOMAIN=localhost
MYSQL_IMAGE_TAG=8.4
MYSQL_CONTAINER_NAME=we-ai-mysql
NGINX_IMAGE_TAG=stable-alpine
NGINX_CONTAINER_NAME=we-ai-nginx
NGINX_PORT=80
MINIO_IMAGE_TAG=latest
MINIO_MC_IMAGE_TAG=latest
MINIO_CONTAINER_NAME=we-ai-minio
MINIO_INIT_CONTAINER_NAME=we-ai-minio-init
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_PUBLIC_BUCKET=we-ai-public
MINIO_PRIVATE_BUCKET=we-ai-private

# Dev bootstrap admin account
APP_AUTH_USERNAME=admin
APP_AUTH_PASSWORD=change-me
JWT_SECRET=change-this-development-secret-key-at-least-32-bytes
JWT_ISSUER=we-ai-server
JWT_ACCESS_TOKEN_EXPIRATION=PT1H
JWT_REFRESH_TOKEN_EXPIRATION=P7D

# Social login
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_REDIRECT_URI=http://localhost/api/v1/auth/kakao/callback
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_REDIRECT_URI=http://localhost/api/v1/auth/naver/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/google/callback
