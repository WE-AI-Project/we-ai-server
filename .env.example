# Database
DB_HOST=localhost
DB_PORT=3307
DB_NAME=we_ai
DB_USERNAME=weai
DB_PASSWORD=change-me-db-password
DB_ROOT_PASSWORD=change-me-root-password

# Local development (IntelliJ backend + Docker support services)
APP_PROFILE=dev
APP_CONTAINER_NAME=we-ai-app-dev
BACKEND_UPSTREAM=host.docker.internal:8080
NGINX_SERVER_NAME=localhost
APP_BASE_URL=http://localhost:8080
APP_FRONTEND_BASE_URL=http://localhost:3000
APP_API_DOMAIN=localhost
APP_FRONTEND_DOMAIN=localhost
APP_STORAGE_CONSOLE_DOMAIN=localhost
MYSQL_IMAGE_TAG=8.4
MYSQL_CONTAINER_NAME=we-ai-mysql-dev
NGINX_IMAGE_TAG=stable-alpine
NGINX_CONTAINER_NAME=we-ai-nginx-dev
NGINX_PORT=8081
MINIO_IMAGE_TAG=latest
MINIO_MC_IMAGE_TAG=latest
MINIO_CONTAINER_NAME=we-ai-minio-dev
MINIO_INIT_CONTAINER_NAME=we-ai-minio-init-dev
MINIO_API_PORT=9100
MINIO_CONSOLE_PORT=9101
MINIO_ENDPOINT=http://localhost:9100
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_PUBLIC_BUCKET=we-ai-public
MINIO_PRIVATE_BUCKET=we-ai-private

# Dev bootstrap admin account
APP_AUTH_USERNAME=admin
APP_AUTH_PASSWORD=change-me
JWT_SECRET=change-this-development-secret-key-at-least-32-bytes
JWT_ISSUER=localhost
JWT_ACCESS_TOKEN_EXPIRATION=PT1H
JWT_REFRESH_TOKEN_EXPIRATION=P7D
SWAGGER_ENABLED=true

# Social login
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_REDIRECT_URI=http://localhost:8080/api/v1/auth/kakao/callback
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_REDIRECT_URI=http://localhost:8080/api/v1/auth/naver/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback

# Verification code delivery
AUTH_VERIFICATION_MOCK_ENABLED=true
AUTH_VERIFICATION_EXPOSE_CODE_IN_RESPONSE=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-sender@example.com
MAIL_PASSWORD=your-app-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
AUTH_VERIFICATION_EMAIL_FROM=your-sender@example.com
