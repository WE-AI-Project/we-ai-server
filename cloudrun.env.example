SPRING_PROFILES_ACTIVE=prod

# Cloud SQL JDBC Socket Factory connection string
# Replace PROJECT_ID:REGION:INSTANCE with your actual Cloud SQL connection name.
DB_URL=jdbc:mysql:///we_ai?cloudSqlInstance=PROJECT_ID:REGION:INSTANCE&socketFactory=com.google.cloud.sql.mysql.SocketFactory&ipTypes=PUBLIC&cloudSqlRefreshStrategy=lazy&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=weai
DB_PASSWORD=change-this-cloud-sql-password

JWT_SECRET=change-this-to-a-random-32-bytes-or-longer-secret
JWT_ISSUER=https://your-cloud-run-url.run.app
JWT_ACCESS_TOKEN_EXPIRATION=PT1H
JWT_REFRESH_TOKEN_EXPIRATION=P7D

APP_BASE_URL=https://your-cloud-run-url.run.app
APP_LOCAL_BASE_URL=https://your-cloud-run-url.run.app
APP_FRONTEND_BASE_URL=https://your-frontend.vercel.app
APP_API_DOMAIN=your-cloud-run-url.run.app
APP_FRONTEND_DOMAIN=your-frontend.vercel.app
APP_STORAGE_CONSOLE_DOMAIN=your-cloud-run-url.run.app

KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_REDIRECT_URI=https://your-cloud-run-url.run.app/api/v1/auth/kakao/callback
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_REDIRECT_URI=https://your-cloud-run-url.run.app/api/v1/auth/naver/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-cloud-run-url.run.app/api/v1/auth/google/callback

AUTH_VERIFICATION_MOCK_ENABLED=false
AUTH_VERIFICATION_EXPOSE_CODE_IN_RESPONSE=false

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-sender@example.com
MAIL_PASSWORD=your-app-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
AUTH_VERIFICATION_EMAIL_FROM=your-sender@example.com

# Keep Swagger enabled until verification is complete, then consider false.
SWAGGER_ENABLED=true
