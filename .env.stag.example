# Staging app runtime
APP_PROFILE=stag
APP_CONTAINER_NAME=we-ai-app
BACKEND_UPSTREAM=app:8080
NGINX_SERVER_NAME=api-stag.example.com
APP_BASE_URL=https://api-stag.example.com
APP_FRONTEND_BASE_URL=https://stag.example.com
APP_API_DOMAIN=api-stag.example.com
APP_FRONTEND_DOMAIN=stag.example.com
APP_STORAGE_CONSOLE_DOMAIN=minio-stag.example.com

# Database
DB_PORT=3306
DB_NAME=we_ai
DB_USERNAME=weai
DB_PASSWORD=change-this-staging-db-password
DB_ROOT_PASSWORD=change-this-staging-root-password

# Docker Compose images
MYSQL_IMAGE_TAG=8.4
MYSQL_CONTAINER_NAME=we-ai-mysql
NGINX_IMAGE_TAG=stable-alpine
NGINX_CONTAINER_NAME=we-ai-nginx
NGINX_PORT=80
MINIO_IMAGE_TAG=latest
MINIO_MC_IMAGE_TAG=latest
MINIO_CONTAINER_NAME=we-ai-minio
MINIO_INIT_CONTAINER_NAME=we-ai-minio-init
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-staging-minio-password
MINIO_PUBLIC_BUCKET=we-ai-public
MINIO_PRIVATE_BUCKET=we-ai-private

# JWT
JWT_SECRET=change-this-staging-secret-key-at-least-32-bytes
JWT_ISSUER=we-ai-staging
JWT_ACCESS_TOKEN_EXPIRATION=PT30M
JWT_REFRESH_TOKEN_EXPIRATION=P7D
SWAGGER_ENABLED=true

# Social login
KAKAO_CLIENT_ID=your-staging-kakao-client-id
KAKAO_REDIRECT_URI=https://api-stag.example.com/api/v1/auth/kakao/callback
NAVER_CLIENT_ID=your-staging-naver-client-id
NAVER_CLIENT_SECRET=your-staging-naver-client-secret
NAVER_REDIRECT_URI=https://api-stag.example.com/api/v1/auth/naver/callback
GOOGLE_CLIENT_ID=your-staging-google-client-id
GOOGLE_CLIENT_SECRET=your-staging-google-client-secret
GOOGLE_REDIRECT_URI=https://api-stag.example.com/api/v1/auth/google/callback
